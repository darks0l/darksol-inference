{
  "name": "darksol",
  "version": "0.4.0",
  "description": "Local-first LLM inference engine with OpenAI-compatible API, MCP tools, and hardware-aware optimization",
  "main": "src/cli.js",
  "type": "module",
  "bin": {
    "darksol": "bin/darksol.js",
    "darksol-studio": "bin/darksol.js"
  },
  "files": [
    "bin/",
    "src/",
    "web/",
    "assets/icons/",
    "package.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "generate:openapi": "node scripts/generate-openapi.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "desktop:dev": "npm --prefix desktop run dev",
    "desktop:build:win": "npm --prefix desktop run build:win",
    "desktop:build:mac": "npm --prefix desktop run build:mac"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "chalk": "^5.0.0",
    "cli-table3": "^0.6.0",
    "commander": "^14.0.0",
    "fastify": "^5.0.0",
    "gpu-orchestrator": "^0.5.0",
    "node-fetch": "^3.0.0",
    "node-llama-cpp": "^3.17.1",
    "ora": "^9.0.0",
    "systeminformation": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.4",
    "typescript": "^5.8.2"
  },
  "keywords": [
    "llm",
    "inference",
    "local-ai",
    "ollama",
    "gguf",
    "llama.cpp",
    "gpu",
    "cli",
    "ai",
    "darksol"
  ],
  "author": "Darksol <chris00claw@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/darks0l/darksol-inference.git"
  },
  "homepage": "https://darksol.cc"
}
