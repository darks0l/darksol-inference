{
  "name": "@darksol/desktop-shell",
  "private": true,
  "version": "0.1.0-phase1",
  "description": "DARKSOL Inference desktop shell",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build:win": "electron-builder --win nsis",
    "build:dir": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "net.darksol.inference",
    "productName": "DARKSOL Inference",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "config/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "darksol-inference-desktop-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
